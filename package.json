{
  "name": "slate-bar",
  "version": "0.3.0",
  "description": "A floating overlay toolbar that injects design variant previews into any localhost page",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./templates": {
      "import": {
        "types": "./dist/templates.d.ts",
        "default": "./dist/templates.js"
      },
      "require": {
        "types": "./dist/templates.d.cts",
        "default": "./dist/templates.cjs"
      }
    }
  },
  "bin": {
    "slate-bar": "bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "commands",
    "cursor-commands",
    "skill",
    "templates/catalog.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "vite --config vite.demo.config.ts",
    "demo:build": "vite build --config vite.demo.config.ts"
  },
  "sideEffects": false,
  "keywords": [
    "toolbar",
    "overlay",
    "design",
    "variants",
    "preview",
    "developer-tools"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
